# ============================================
# Authentication & Security Configuration
# ============================================
API_KEY_ADMIN=admin-secret-key-change-in-production
API_KEY_USER=user-secret-key-change-in-production
API_KEY_READONLY=readonly-secret-key-change-in-production

# ============================================
# Rate Limiting Configuration
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_ADMIN=1000
RATE_LIMIT_USER=100
RATE_LIMIT_READONLY=50
RATE_LIMIT_ANONYMOUS=10

# ============================================
# Core Services Configuration
# ============================================
POSTGRES_DB=mlops
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXPIRE_SECONDS=86400
REDIS_EXPIRE_DAYS=30
REDIS_MAX_CONNECTIONS=10

# ============================================
# MLflow Configuration
# ============================================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_PORT=5000
MLFLOW_ARTIFACT_PATH=s3://mlflow/
MLFLOW_S3_ENDPOINT_URL=http://garage:3900

# ============================================
# Model Configuration
# ============================================
MODEL_NAME=churn_model
EXPERIMENT_NAME=customer_churn
COLUMNS_FILE=columns.pkl
DATA_PATH=data/churn.csv

# ============================================
# API Configuration
# ============================================
API_PORT=8000
API_ROOT_PATH=/api
API_HOST=0.0.0.0
PUBLIC_URL=http://localhost:8080

# ============================================
# Service Names (for logging)
# ============================================
SERVICE_NAME_API=api
SERVICE_NAME_WORKER=worker
SERVICE_NAME_TRAINER=trainer

# ============================================
# Cache Configuration
# ============================================
CACHE_TTL_SECONDS=3600
BATCH_EXPIRY_SECONDS=86400
RETRAIN_BATCH_SIZE=1000
MAX_BATCH_RECORDS=10000

# ============================================
# Timeout & Retry Configuration
# ============================================
HEALTH_TIMEOUT=30
SOCKET_TIMEOUT=5
TASK_TIMEOUT_SECONDS=1800
TASK_SOFT_TIMEOUT_SECONDS=1500
RETRY_COUNTDOWN_SECONDS=60
MAX_RETRIES=3
UPTIME_MOCK_SECONDS=3600

# ============================================
# Fluent-bit & Logging
# ============================================
FLUENT_BIT_URL=http://fluent-bit:8888
FLUENT_BIT_PORT=8888
FLUENT_BIT_MONITOR_PORT=2020
FLUENT_BIT_BATCH_SIZE=10
FLUENT_BIT_FLUSH_INTERVAL=1.0
LOG_LEVEL=INFO

# ============================================
# Prometheus & Metrics
# ============================================
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_PORT=9090

# ============================================
# Grafana Configuration
# ============================================
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:8080/grafana/

# ============================================
# Nginx Configuration
# ============================================
NGINX_PORT=8080
NGINX_INTERNAL_PORT=80

# ============================================
# Docker/Container Configuration
# ============================================
DOCKER_REGISTRY=docker.arvancloud.ir
DOCKER_TLS_CERTDIR=/certs
PIP_INDEX_URL=https://pypi.devneeds.ir/simple/
PIP_TRUSTED_HOST=pypi.devneeds.ir
APT_MIRROR=http://linux-mirror.liara.ir/repository/debian
APT_MIRROR_SECURITY=http://linux-mirror.liara.ir/repository/debian-security
SELINUX=:z
SELINUX_RO=,z

# ============================================
# Python Runtime
# ============================================
PYTHONUNBUFFERED=1

# ============================================
# Testing
# ============================================
TESTING=false

# ============================================
# Retrain Queue Configuration
# ============================================
RETRAIN_QUEUE_KEY=retrain:training_data
RETRAIN_QUEUE_MAX_LENGTH=100000
DRIFT_REPORT_PATH=/tmp

# ============================================
# AWS/Garage S3 Configuration
# ============================================
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=GKfbec872391d6589750e7da19
