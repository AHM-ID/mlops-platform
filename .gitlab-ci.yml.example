stages:
  - test
  - build

variables:
  DOCKER_REGISTRY: docker.io
  PIP_INDEX_URL: "https://pypi.org/simple/"
  PIP_TRUSTED_HOST: "pypi.org"
  APT_MIRROR: "http://deb.debian.org/debian"
  APT_MIRROR_SECURITY: "http://security.debian.org/debian-security"
  PIP_CACHE_DIR: "$CI_PROJECT_DIR/.cache/pip"
  PIP_DISABLE_PIP_VERSION_CHECK: "1"
  TESTING: "true"

test:
  stage: test
  image: ${DOCKER_REGISTRY}/python:3.11.9-slim
  timeout: 45m
  cache:
    key: pip-py311
    paths:
      - .cache/pip
  rules:
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"
    - if: $CI_COMMIT_BRANCH
  before_script:
    - mkdir -p .cache/pip
    - chmod +x scripts/ci_install_deps.sh
    - scripts/ci_install_deps.sh
  script:
    - python -m pytest tests/ -v -m "not integration" --tb=short

build:
  stage: build
  image:
    name: gcr.io/kaniko-project/executor:debug
    entrypoint: [""]
  rules:
    - if: $CI_COMMIT_BRANCH == "main"
  before_script:
    - mkdir -p /kaniko/.docker
    - |
      cat > /kaniko/.docker/config.json << EOF
      {
        "auths": {
          "${HARBOR_REGISTRY}": {
            "username": "${HARBOR_USERNAME}",
            "password": "${HARBOR_PASSWORD}"
          }
        }
      }
      EOF
  script:
    - |
      /kaniko/executor \
        --context ${CI_PROJECT_DIR} \
        --dockerfile ${CI_PROJECT_DIR}/Dockerfile \
        --destination ${HARBOR_IMAGE}:${CI_COMMIT_SHORT_SHA} \
        --destination ${HARBOR_IMAGE}:latest \
        --build-arg DOCKER_REGISTRY=${DOCKER_REGISTRY} \
        --build-arg PIP_INDEX_URL=${PIP_INDEX_URL} \
        --build-arg PIP_TRUSTED_HOST=${PIP_TRUSTED_HOST} \
        --build-arg APT_MIRROR=${APT_MIRROR} \
        --build-arg APT_MIRROR_SECURITY=${APT_MIRROR_SECURITY} \
        --cache=true \
        --cache-repo=${HARBOR_REGISTRY}/${HARBOR_IMAGE}/cache