stages:
  - test
  - build
  - deploy

test:
  stage: test
  image: ${DOCKER_REGISTRY}/python:3.11.9-slim
  variables:
    TESTING: "true"
    RATE_LIMIT_ENABLED: "false"
    PROMETHEUS_MULTIPROC_DIR: /tmp/prometheus-test
    MLFLOW_TRACKING_URI: http://localhost:5000
    REDIS_URL: redis://localhost:6379/0
    POSTGRES_HOST: localhost
    API_KEY_ADMIN: admin-secret-key-change-in-production
    API_KEY_USER: user-secret-key-change-in-production
    API_KEY_READONLY: readonly-secret-key-change-in-production
  before_script:
    - mkdir -p "$PROMETHEUS_MULTIPROC_DIR"
    - python -m pip install --trusted-host ${PIP_TRUSTED_HOST} -i ${PIP_INDEX_URL} -r requirements.txt
  script:
    - python -m pytest tests/ -v -m "not integration" --tb=short

build:
  stage: build
  image: ${DOCKER_REGISTRY}/docker:24
  services:
    - docker:24-dind
  script:
    # Use docker buildkit for caching
    - docker build -t churn-api:latest .

deploy:
  stage: deploy
  image: ${DOCKER_REGISTRY}/bitnami/kubectl:latest
  script:
    - kubectl apply -f infra/k8s/
  only:
    - main
